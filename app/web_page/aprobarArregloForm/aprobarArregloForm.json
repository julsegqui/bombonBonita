    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.nuevoArreglo ){",
        "\treturn {",
        "\t\t//map nuevoArreglo variable to expected task contract input",
        "\t\tnuevoArregloInput: {",
        "\t\t\tdescripcionArreglo: $data.nuevoArreglo.descripcionArreglo !== undefined ? $data.nuevoArreglo.descripcionArreglo : null,",
        "\t\t\tarregloAprobado: $data.nuevoArreglo.arregloAprobado !== undefined ? $data.nuevoArreglo.arregloAprobado : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "nuevoArreglo" : {
