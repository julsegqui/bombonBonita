      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.nuevaOrden ){",
        "\treturn {",
        "\t\t//map nuevaOrden variable to expected task contract input",
        "\t\tnuevaOrdenInput: {",
        "\t\t\treferenciaOdoo: $data.nuevaOrden.referenciaOdoo !== undefined ? $data.nuevaOrden.referenciaOdoo : null,",
        "\t\t\tnombreCliente: $data.nuevaOrden.nombreCliente !== undefined ? $data.nuevaOrden.nombreCliente : null,",
        "\t\t\temailClienta: $data.nuevaOrden.emailClienta !== undefined ? $data.nuevaOrden.emailClienta : null,",
        "\t\t\tdescripcionArreglo: $data.nuevaOrden.descripcionArreglo !== undefined ? $data.nuevaOrden.descripcionArreglo : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
